{
  "name": "last-say",
  "version": "0.2.3",
  "private": true,
  "description": "Local-first, human-in-the-loop finance review where AI prepares and you have the last say.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cablate/last-say.git"
  },
  "bugs": {
    "url": "https://github.com/cablate/last-say/issues"
  },
  "homepage": "https://github.com/cablate/last-say#readme",
  "keywords": [
    "local-first",
    "human-in-the-loop",
    "personal-finance",
    "ai-agent",
    "sqlite"
  ],
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 3127",
    "build": "next build",
    "start": "next start -H 127.0.0.1 -p 3127",
    "lint": "eslint . --max-warnings=0",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "test": "node --test",
    "smoke:runtime": "node scripts/smoke-runtime.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "eval:skill": "node scripts/eval-last-say-skill.mjs",
    "seed": "node scripts/seed-from-ledger.js",
    "seed:reset": "node scripts/seed-from-ledger.js --reset",
    "seed:demo": "node scripts/seed-demo.js",
    "seed:demo:reset": "node scripts/seed-demo.js --reset"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "^15.5.20",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@eslint/eslintrc": "^3.3.6",
    "eslint": "^9.39.5",
    "eslint-config-next": "^15.5.20",
    "shadcn": "^4.13.1",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
