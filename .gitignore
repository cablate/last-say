# dependencies
node_modules/

# next.js
.next/
.next-dev/
.next-verify/
out/
next-env.d.ts

# production
build/

# === 機敏：真實財務 DB 絕不追蹤（整個 data/ 只留 .gitkeep，避免任何備份變體漏網）===
data/*
!data/.gitkeep

# 全域：任何位置的 sqlite DB 與備份變體都擋（根目錄 scratch DB、任意子目錄的備份）
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.sqlite.bak*

# imports (uploaded CSV may contain real statements)
uploads/
outputs/

# 全域：非 cathay 銀行原始 CSV 也擋（真實帳單應放 uploads/），但保留 docs 範例
*.csv
!docs/**/*.csv

# root 帳單原始 CSV（真實財務，應放 uploads/；若放 root 也要忽略，避免 git add -A 誤 commit）
cathay-credit-card-*.csv

# logs / pid
*.log
server.pid

# screenshots may contain real transaction data — don't commit
*.png
# local consultation / UI audit bundles may also contain written personal figures
/audit/
# ...but keep committed demo screenshots and brand assets under docs/
!docs/screenshots/*.png
!docs/brand/*.jpg

# misc
.DS_Store
Thumbs.db
.playwright-mcp/
.env*
!.env.example

# internal docs (contain personal context / local paths, not for public)
AUDIT-*.md
DESIGN.md
DEV-JOURNAL.md
PRINCIPLES-RAW.md
.vscode/
.idea/

# tool indexes (local only, not for repo)
.codegraph/
.serena/
